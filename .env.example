# ==========================================
# CREDENCIALES DE SUPABASE Y GEMINI
# ==========================================

# El URI de PostgreSQL (Obligatorio para el Backend y Agente)
DB_DSN="postgresql://postgres.[tu_proyecto]:[tu_password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres"

# La API Key de Google Gemini (Obligatorio para el Agente)
GEMINI_API_KEY="tu_google_gemini_api_key"

# Fallback LLM cuando Gemini devuelve 503/429 (opcional pero recomendado)
GROQ_API_KEY="tu_groq_api_key"
GROQ_MODEL="llama-3.3-70b-versatile"

# API Key de Cohere (Obligatorio para embeddings RAG)
COHERE_API_KEY="tu_cohere_api_key"

# ==========================================
# CREDENCIALES DEL DASHBOARD (Streamlit)
# ==========================================
SUPABASE_URL="https://[tu_proyecto].supabase.co"
SUPABASE_KEY="tu_service_role_key"

# ==========================================
# SEGURIDAD DE LA API (FastAPI)
# ==========================================
# Esta es la contraseña que n8n debe enviar en el header X-API-Key
API_KEY="token-secreto-n8n-12345"

# ==========================================
# CONFIGURACIÓN DEL MICRO-BATCHING
# ==========================================
BATCH_SIZE=50
GEMINI_CONCURRENCY=10
BATCH_INTERVAL_MINUTES=5
MAX_RETRIES=2

# ==========================================
# RAG COPILOT (Fase 5)
# ==========================================
EMBED_BATCH_SIZE=50
EMBED_MAX_PER_RUN=500
EMBED_JOB_SLEEP_SECONDS=2
COPILOT_MATCH_COUNT=10
COPILOT_DEFAULT_SINCE_DAYS=7

# URL del backend FastAPI (para el Copilot en Streamlit)
FASTAPI_URL="http://localhost:8000"

# URL que usa n8n (Docker) para enviar feedback al ingest
FASTAPI_INGEST_URL="http://host.docker.internal:8000/ingest"

# ==========================================
# n8n — WEBHOOKS (ngrok para WhatsApp / Meta)
# ==========================================
# Base pública HTTPS (termina con /). Local sin túnel: http://localhost:5679/
WEBHOOK_URL="https://tu-subdominio.ngrok-free.app/"

# Token de verificación Meta = UUID del nodo "On messages" (Production URL en n8n).
WHATSAPP_VERIFY_TOKEN=uuid-del-nodo-whatsapp-trigger

# URL completa del callback para Meta Developers (Production URL del nodo).
WHATSAPP_WEBHOOK_CALLBACK_URL=https://tu-subdominio.ngrok-free.app/webhook/uuid-del-nodo/webhook
