# Variables de entorno para producción (plantilla — sin secretos reales)
# Copiar a .env en el servidor o usar un secrets manager (Fly.io, Vault, etc.).
# Generar API_KEY: openssl rand -hex 32

# Entorno
ENV=production

# PostgreSQL (Session pooler Supabase) — escritura para API y worker
DB_DSN=postgresql://postgres.[proyecto]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# APIs externas (completar en el servidor — no commitear valores reales)
GEMINI_API_KEY=
GROQ_API_KEY=
COHERE_API_KEY=

# Supabase — dashboard (SOLO lectura, ver docs/guides/bi-readonly-setup.md)
SUPABASE_URL=https://[proyecto].supabase.co
SUPABASE_KEY=
DASHBOARD_READONLY=true

# Seguridad FastAPI (obligatorio en producción, mínimo 32 caracteres)
API_KEY=

# CORS — origen del dashboard interno (comma-separated si varios)
CORS_ORIGINS=https://dashboard.[tu-dominio].com

# Rate limiting (requests por IP por minuto)
RATE_LIMIT_INGEST_PER_MINUTE=60
RATE_LIMIT_COPILOT_PER_MINUTE=30

# Worker — cola DB
BATCH_SIZE=50
BATCH_INTERVAL_MINUTES=5
MAX_RETRIES=4
STUCK_PROCESSING_MINUTES=30

# Worker — clasificación LLM (optimización tokens)
GEMINI_CONCURRENCY=3
CLASSIFY_RETRY_ATTEMPTS=3
CLASSIFY_RETRY_BASE_SECONDS=2
CLASSIFY_LLM_BATCH_SIZE=8
CLASSIFY_MAX_TEXT_CHARS=300
GEMINI_CACHE_ENABLED=true
GEMINI_CACHE_TTL_SECONDS=3600
GEMINI_CACHE_VERSION=v2-fewshot1
GEMINI_MODEL=gemini-2.5-flash-lite
GROQ_MODEL=llama-3.3-70b-versatile

# RAG Copilot
EMBED_BATCH_SIZE=50
EMBED_MAX_PER_RUN=500
EMBED_JOB_SLEEP_SECONDS=2
COPILOT_MATCH_COUNT=10

# URLs internas Docker
FASTAPI_URL=http://api:8000
FASTAPI_INGEST_URL=http://api:8000/ingest
WEBHOOK_URL=https://[tu-dominio-publico]/

# Imagen Docker (opcional, para docker-compose.prod.yml)
IMAGE_TAG=latest
