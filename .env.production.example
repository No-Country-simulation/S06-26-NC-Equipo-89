# Variables de entorno para producción (sin secretos reales)
# Copiar a .env y completar valores en el servidor o secrets manager.

# PostgreSQL (Session pooler Supabase)
DB_DSN=postgresql://postgres.[proyecto]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# APIs externas
GEMINI_API_KEY=
COHERE_API_KEY=

# Supabase (dashboard)
SUPABASE_URL=https://[proyecto].supabase.co
SUPABASE_KEY=

# Seguridad FastAPI
API_KEY=

# Worker
BATCH_SIZE=50
GEMINI_CONCURRENCY=10
BATCH_INTERVAL_MINUTES=5
MAX_RETRIES=2

# RAG Copilot
EMBED_BATCH_SIZE=50
EMBED_MAX_PER_RUN=500
EMBED_JOB_SLEEP_SECONDS=2
COPILOT_MATCH_COUNT=10
COPILOT_DEFAULT_SINCE_DAYS=7

# URLs internas Docker
FASTAPI_URL=http://api:8000
FASTAPI_INGEST_URL=http://api:8000/ingest
